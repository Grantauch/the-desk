const resources = [
  { label: 'Google Classroom', href: 'https://classroom.google.com' },
  { label: 'Chronicling America — historic newspapers', href: 'https://chroniclingamerica.loc.gov' },
  { label: 'Library of Congress — sports collections', href: 'https://www.loc.gov/collections/' },
