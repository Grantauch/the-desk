---
// beyond-the-scoreboard.astro — edit the data below; the layout comes from CoursePage.
// Mark exactly one unit `current: true` to feature it in the "right now" box.
import CoursePage from '../components/CoursePage.astro';
import QuickTake from '../components/QuickTake.astro';
import TodayCard from '../components/TodayCard.astro';
import DailyCard from '../components/DailyCard.astro';
import DailyDesk from '../components/DailyDesk.astro';

// ---- argue this: one bellringer a day ----
const argueThis = [
  { tag: 'make the call', text: 'Sport: mirror or engine? Take today’s side using any case we’ve studied. You may not say "both" until you’ve earned it.' },
  { tag: 'make the call', text: 'Should college athletes have been paid all along? Argue it from 1950 first, then from today. Notice what changed.' },
  { tag: 'make the call', text: 'Ali lost his prime years to a principle. Would today’s leagues—and today’s sponsors—survive an athlete like that?' },
  { tag: 'make the call', text: 'Are public subsidies for stadiums ever worth it? Follow the money.' },
  { tag: 'make the call', text: 'Smith and Carlos, 1968: was the podium the right forum or the wrong one? Now answer for a player kneeling in 2016. Same answer?' },
  { tag: 'make the call', text: 'Does legalized betting change what sports are, or just who profits from them?' },
  { tag: 'make the call', text: 'Title IX: finished business or unfinished? Point to the money before you answer.' },
  { tag: 'make the call', text: 'The transfer portal and NIL: player freedom, or the end of college sports as we knew them?' },
];

// ---- this day in sports (m = month, d = day, y = year) ----
const sportsEvents = [
  { m: 1, d: 15, y: 1967, text: 'Super Bowl I: Packers 35, Chiefs 10. Tickets went for $12, the stadium wasn’t full, and two networks broadcast it at once because nobody knew whose game it was yet.' },
  { m: 1, d: 25, y: 1924, text: 'The first Winter Olympics opens in Chamonix, France. Sixteen nations, and a new argument — which sports count — that hasn’t ended since.' },
  { m: 2, d: 22, y: 1980, text: 'The Miracle on Ice: US college kids beat the Soviet machine 4–3 at Lake Placid. A hockey game that half the country still remembers as a Cold War battle — which is the whole thesis of this course.' },
  { m: 2, d: 25, y: 1964, text: 'Cassius Clay upsets Sonny Liston in Miami Beach. Days later he announces his new name: Muhammad Ali. The most consequential athlete of the century has arrived, loudly.' },
  { m: 3, d: 2, y: 1962, text: 'Wilt Chamberlain scores 100 points in Hershey, Pennsylvania. No TV cameras, one grainy photo of him holding a piece of paper. Sometimes the primary source is a box score and 4,000 witnesses.' },
  { m: 3, d: 26, y: 1979, text: 'Magic Johnson’s Michigan State beats Larry Bird’s Indiana State for the NCAA title — still the highest-rated basketball game in US TV history. The NBA’s next two decades start here.' },
  { m: 4, d: 8, y: 1974, text: 'Hank Aaron hits home run 715, passing Babe Ruth — after a year of hate mail and death threats. Two white college kids ran onto the field; he later said he never knew if they meant harm.' },
  { m: 4, d: 15, y: 1947, text: 'Jackie Robinson takes first base at Ebbets Field, breaking major league baseball’s color line. Not a spontaneous moment — a plan, years in the making, executed under unbearable rules of engagement.' },
  { m: 5, d: 2, y: 1939, text: 'Lou Gehrig benches himself after 2,130 consecutive games, ending the streak on his own terms. The disease that forced it now carries his name.' },
  { m: 5, d: 25, y: 1935, text: 'Jesse Owens, at the Big Ten meet in Ann Arbor, breaks three world records and ties a fourth — in 45 minutes, with a sore back. Arguably the greatest single day any athlete ever had, and it happened in Michigan.' },
  { m: 6, d: 22, y: 1938, text: 'Joe Louis knocks out Max Schmeling in 124 seconds at Yankee Stadium. Detroit’s own, carrying a democracy-vs-fascism rematch on his back. Sport as world politics, two minutes long.' },
  { m: 6, d: 23, y: 1972, text: 'Title IX is signed into law — thirty-seven words that never mention sports and rebuilt American athletics anyway. Girls’ high school sports participation grew roughly tenfold in a decade.' },
  { m: 7, d: 4, y: 1939, text: '"Today I consider myself the luckiest man on the face of the earth." Lou Gehrig, dying and knowing it, delivers sport’s Gettysburg Address at Yankee Stadium.' },
  { m: 7, d: 10, y: 1999, text: 'The US wins the Women’s World Cup on penalty kicks at the Rose Bowl. Brandi Chastain’s celebration becomes an era-defining photo, and women’s sports gains its proof-of-market moment.' },
  { m: 8, d: 3, y: 1936, text: 'Jesse Owens wins the 100 meters at the Berlin Olympics, the first of four golds — in a stadium built to showcase a racial theory he spent the week disproving.' },
  { m: 8, d: 9, y: 2012, text: 'Claressa Shields of Flint, age 17, wins the first US women’s boxing gold in Olympic history. She does it again in 2016. Your capstone has local material.' },
  { m: 9, d: 20, y: 1973, text: 'The Battle of the Sexes: Billie Jean King beats Bobby Riggs in the Astrodome before 90 million TV viewers. A circus with real stakes — she understood exactly what losing would have cost.' },
  { m: 9, d: 21, y: 1970, text: 'Monday Night Football debuts. Sports moves to prime time, and the argument about whether the game serves TV or TV serves the game is officially over. TV won.' },
  { m: 10, d: 1, y: 1961, text: 'Roger Maris hits home run 61 on the season’s last day, passing Ruth while losing his hair from the stress. The record book fought him harder than the pitchers did.' },
  { m: 10, d: 16, y: 1968, text: 'Tommie Smith and John Carlos raise gloved fists on the Olympic podium in Mexico City. Expelled from the Games within days; on the right side of the highlight reel ever since.' },
  { m: 11, d: 6, y: 1869, text: 'Rutgers beats Princeton 6–4 in the first college football game. Twenty-five players a side, no forward pass, and no idea what they’d started.' },
  { m: 11, d: 19, y: 2004, text: 'The Malice at the Palace, Auburn Hills, Michigan. A brawl between players and fans becomes a referendum on race, class, and who gets blamed — we study the coverage as closely as the fight.' },
  { m: 12, d: 26, y: 1908, text: 'Jack Johnson beats Tommy Burns in Sydney to become the first Black heavyweight champion. The search for a "great white hope" begins immediately — and says more about America than the fight did.' },
  { m: 12, d: 28, y: 1958, text: 'Colts 23, Giants 17 in sudden-death overtime — "the greatest game ever played." Forty-five million watched, and the NFL’s television age began in the dark at Yankee Stadium.' },
];

// ---- the stat that tells a story ----
const stats = [
  { tag: 'the stat: 37 words', text: 'The entire text of Title IX fits in a tweet and never mentions sports. Thirty-seven words rebuilt who gets to play — proof that the law thread of this course is not the boring one.' },
  { tag: 'the stat: $80,000', text: 'Babe Ruth’s 1930 salary — more than President Hoover’s. Asked about it, the story goes, Ruth said: "I had a better year than he did." The Depression had just started. He wasn’t wrong.' },
  { tag: 'the stat: 90,185', text: 'Attendance at the 1999 Women’s World Cup final — still among the largest crowds ever for a women’s sporting event. The "nobody watches" argument lost 90,185 to nothing that day.' },
  { tag: 'the stat: 24 seconds', text: 'The shot clock, adopted in 1954 after a 19–18 NBA game involving the Pistons (then of Fort Wayne) nearly bored the league to death. Sometimes the rulebook is a defibrillator.' },
  { tag: 'the stat: 930,000', text: 'Letters Hank Aaron received in 1973 while chasing Ruth’s record — more mail than anyone in America that year. Much of it was vile. He kept it. Historians are glad he did.' },
  { tag: 'the stat: 8', text: 'White Sox players banned for life for throwing the 1919 World Series — including one who hit .375 in the series he was accused of throwing. The scandal invented the all-powerful commissioner.' },
  { tag: 'the stat: 261', text: 'Kathrine Switzer’s bib number when she ran the 1967 Boston Marathon — an official tried to drag her off the course mid-race. Women were officially admitted in 1972. The photos did the arguing.' },
  { tag: 'the stat: 18', text: 'At least eighteen players died playing college football in 1905. President Theodore Roosevelt summoned the colleges to the White House; the forward pass was legalized within the year. Reform, or the game was done.' },
];

// ---- the rulebook remembers ----
const rules = [
  { tag: 'rule change, 1906', text: 'The forward pass is legalized — not as innovation, but as triage after the deadly 1905 season. Every spiral you’ve ever seen exists because the alternative was abolition.' },
  { tag: 'rule change, 1944', text: 'Goaltending banned. College giants had started standing under the rim swatting everything on the way down, and basketball briefly stopped being basketball.' },
  { tag: 'rule change, 1973', text: 'The American League adopts the designated hitter. Fifty years of arguments follow, which by baseball standards makes it a fresh controversy.' },
  { tag: 'rule change, 1975', text: 'An arbitrator rules pitchers Messersmith and McNally are free agents, killing the reserve clause that bound players to teams for life. Curt Flood lost his case but won the war — this is the labor thread’s biggest moment.' },
  { tag: 'rule change, 1979', text: 'The NBA adopts the three-point line — an ABA gimmick, imported when the leagues merged. It took decades to matter, and now it IS the sport. Rule changes compound like interest.' },
  { tag: 'rule change, 1972', text: 'The NCAA lets freshmen play varsity basketball and football. Smaller rosters of upperclassmen give way to instant stars — and one-and-done is this rule’s great-grandchild.' },
  { tag: 'rule change, 1986', text: 'The NFL adopts instant replay. The camera outranks the human eye for the first time, and the media thread officially enters the rulebook itself.' },
  { tag: 'rule change, 2021', text: 'NIL: college athletes can finally earn money from their name, image, and likeness — on July 1, the amateurism wall cracked after a century. Your unit 6 is being written in real time.' },
];

