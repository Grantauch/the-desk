const glossary = [
  { term: 'the color line', def: 'The rule — written and unwritten — that kept Black athletes out of white leagues for half a century. Drawn on purpose, defended on purpose, broken on purpose.' },
  { term: 'reserve clause', def: 'The contract rule that bound a player to one team for life, at whatever the team offered. It took a Supreme Court case and a union to kill it.' },
  { term: 'free agency', def: 'A player’s right to sell their labor to the highest bidder — standard in every other job, revolutionary in sports.' },
  { term: 'amateurism', def: 'The rule that athletes shouldn’t be paid, invented by people who were being paid. The college version lasted a century before NIL cracked it.' },
  { term: 'title ix', def: 'The 1972 law barring sex discrimination in federally funded education — thirty-seven words that transformed who gets to play.' },
  { term: 'nil', def: 'Name, image, and likeness — a college athlete’s right to earn money from being themselves. The newest chapter in the oldest fight in sports.' },
  { term: 'barnstorming', def: 'Touring teams playing exhibition games town to town — how the Negro Leagues and early pros reached fans the big leagues ignored.' },
  { term: 'boycott', def: 'Refusing to play as protest. From the 1968 Olympic project to modern walkouts, the threat of an empty arena is leverage.' },
  { term: 'broadcast rights', def: 'The money engine of modern sports: leagues sell the right to show games, and everything from realignment to start times follows the checks.' },
  { term: 'sanctioning body', def: 'The organization that makes the rules and enforces them — leagues, the NCAA, the IOC. Every era’s fights end up on their desk.' },
  { term: 'mirror or engine', def: 'The course question: does sport reflect American society, or drive it? Every unit adds a tally mark to one side. The final answer is yours.' },
];
---

<CoursePage
  title="beyond the scoreboard"
  tagline="american history through sports. the games were never just games."
  intro="This course uses sports as a lens on America from the 1860s to today. Every unit follows four threads — business and labor, media and technology, law and government, and the fight over who gets to play — using real primary sources: newspapers, broadcast footage, court decisions, congressional testimony. We read what people said at the time before deciding what we think now; that's what separates history from hot takes. It ends with a research capstone on a sports story from Michigan's own backyard."
  units={units}
  resources={resources}
  glossary={glossary}
/>
