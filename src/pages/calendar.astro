---
// calendar.astro — key dates for all classes. Edit the arrays below.
// TODO(Grant): replace the placeholder dates with the real 2026-27 district calendar.
// `course` controls the accent tag; use 'all classes' for school-wide dates.
import Base from '../layouts/Base.astro';

const dates = [
  { when: 'sept 8', course: 'all classes', what: 'first day of school (TODO: confirm district start date)' },
  { when: 'sept — week 1', course: 'hidden history', what: 'the Roswell headline reveal + day-one exit tickets (you get them back in june)' },
  { when: 'sept — week 1', course: 'beyond the scoreboard', what: 'the Louis–Schmeling cold open' },
  { when: 'oct — week 6', course: 'hidden history', what: 'unit 2 test: follow the evidence' },
  { when: 'oct — week 6', course: 'beyond the scoreboard', what: 'unit 2 test: the national stage' },
  { when: 'nov — week 12', course: 'hidden history', what: 'trust and verify: the myth stations week' },
  { when: 'dec — week 15', course: 'hidden history', what: 'the surveillance debate (structured, sourced, scored)' },
  { when: 'dec — week 15', course: 'beyond the scoreboard', what: 'michigan capstone: topics locked, teams set' },
  { when: 'jan — week 18', course: 'hidden history', what: 'case file capstone presentations + semester exam' },
  { when: 'jan — week 18', course: 'beyond the scoreboard', what: 'michigan capstone presentations + final exam' },
  { when: 'jan — sem 2', course: 'us history', what: 'semester 2 begins — the cold war cometh' },
  { when: 'june', course: 'all classes', what: 'last week: day-one exit tickets return. see how far you came.' },
];
---

<Base title="calendar" description="key dates for every class at the desk.">
  <h1 class="font-display text-5xl sm:text-6xl font-bold lowercase tracking-tight">
    calendar<span class="text-accent">.</span>
  </h1>
  <p class="mt-3 text-lg text-ink-soft lowercase">the dates worth writing down. tests, capstones, and reckonings.</p>
  <p class="mt-2 text-sm font-mono lowercase text-ink-soft">assignments and due dates live in google classroom — this is the big picture.</p>

  <ul class="mt-10 space-y-3">
    {
      dates.map((d) => (
        <li class="flex gap-4 items-baseline border-b-2 border-line pb-3">
          <span class="font-mono text-xs bg-accent-soft text-accent-dark px-2 py-0.5 shrink-0 lowercase">{d.when}</span>
          <div>
            <span>{d.what}</span>
            <span class="ml-2 text-xs font-mono lowercase text-accent">{d.course}</span>
          </div>
        </li>
      ))
    }
  </ul>
</Base>
