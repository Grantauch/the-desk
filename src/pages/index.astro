---
// index.astro — the home page.
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const announcements = (await getCollection('announcements'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const courses = [
  {
    href: '/us-history/',
    name: 'us history',
    theme: 'history',
    identity: 'american archive',
    blurb: 'reconstruction to right now — the people, choices, disasters, and breakthroughs that still explain the country.',
  },
  {
    href: '/hidden-history/',
    name: 'hidden history',
    theme: 'classified',
    identity: 'evidence desk',
    blurb: 'coverups, conspiracies, hoaxes, and the evidence that separates the documented from the nonsense.',
  },
  {
    href: '/beyond-the-scoreboard/',
    name: 'beyond the scoreboard',
    theme: 'scoreboard',
    identity: 'film room',
    blurb: 'american history through sports. the games were never just games.',
  },
];

const currentCourseNames = ['US History', 'Hidden History', 'Beyond the Scoreboard'];

const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' });
---

<Base>
  <!-- hero -->
  <section class="py-12 dot-grid">
    <h1 class="font-display text-7xl sm:text-8xl font-bold lowercase tracking-tight">
      the desk<span class="text-accent">.</span>
    </h1>
    <p class="mt-5 text-lg text-ink-soft max-w-xl">
      Three history classes, one ridiculous pile of stories. Slides, games, sources, and today’s best detours live here.
    </p>
  </section>

  <!-- library search -->
  <section id="library-search" class="home-library scroll-mt-32 p-5 sm:p-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="max-w-xl">
        <p class="font-mono text-xs font-semibold lowercase text-accent">the whole desk, searchable</p>
        <h2 class="mt-1 font-display text-3xl font-bold lowercase">
          find the lesson before the bell<span class="text-accent">.</span>
        </h2>
        <p class="mt-2 leading-relaxed text-ink-soft">
          Search slides, packets, games, readings, and activities from every class.
        </p>
      </div>
      <a href="/resources/" class="font-mono text-xs font-semibold lowercase text-accent hover:text-accent-dark">
        browse the stacks →
      </a>
    </div>

    <form action="/resources/" method="get" class="mt-5 grid gap-3 sm:grid-cols-[1fr_auto]">
      <input type="hidden" name="scope" value="all" />
      <label>
        <span class="sr-only">Search the resource library</span>
        <input
          type="search"
          name="q"
          required
          placeholder="try: roswell, reconstruction, d-day…"
          class="w-full rounded-xl border border-line bg-white px-4 py-3 outline-none transition-colors focus:border-accent"
        />
      </label>
      <button type="submit" class="rounded-xl border border-accent-dark bg-accent px-5 py-3 font-mono text-sm font-semibold lowercase text-white shadow-[0_12px_24px_-18px_var(--color-accent)] transition-all hover:-translate-y-0.5 hover:bg-accent-dark">
        search library
      </button>
    </form>

    <nav class="mt-4 flex flex-wrap gap-2" aria-label="Current course resource libraries">
      {
        currentCourseNames.map((course) => (
          <a
            href={`/resources/?course=${encodeURIComponent(course)}`}
            class="rounded-md border border-line bg-paper px-2.5 py-1.5 font-mono text-[0.7rem] font-semibold lowercase text-ink-soft transition-colors hover:border-accent hover:text-accent"
          >
            {course}
          </a>
        ))
      }
    </nav>
  </section>

  <!-- classes -->
  <section id="courses" class="mt-10 grid scroll-mt-32 gap-6 sm:grid-cols-3">
    {
      courses.map((c, i) => (
        <a href={c.href} class="home-course-card group p-5" data-course={c.theme}>
          <span class="home-course-card__ghost" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <span class="home-course-card__identity">{String(i + 1).padStart(2, '0')} // {c.identity}</span>
          <h2 class="home-course-card__title">
            {c.name}<span>.</span>
          </h2>
          <p class="home-course-card__blurb">{c.blurb}</p>
          <span class="home-course-card__cta">open class <span aria-hidden="true">→</span></span>
        </a>
      ))
    }
  </section>

  <!-- the fun stuff -->
  <section class="mt-10 grid gap-6 sm:grid-cols-2">
    <a href="/simulations/" class="home-feature-card group pop bg-accent p-5 text-white">
      <h2 class="font-display text-2xl font-bold lowercase">simulations<span class="text-white/60">.</span></h2>
      <p class="mt-2 text-sm text-white/85 leading-relaxed">
        Hearings, debates, investigations, and the days the desks start moving.
      </p>
      <span class="mt-3 inline-block transition-transform group-hover:translate-x-1.5">→</span>
    </a>
    <a href="/games/" class="home-feature-card group pop bg-white p-5">
      <h2 class="font-display text-2xl font-bold lowercase group-hover:text-accent transition-colors">games<span class="text-accent">.</span></h2>
      <p class="mt-2 text-sm text-ink-soft leading-relaxed">
        Jeopardy boards, lessonhubs, and review games. Open one and start yelling answers.
      </p>
      <span class="mt-3 inline-block text-accent transition-transform group-hover:translate-x-1.5">→</span>
    </a>
    <a href="/rabbit-holes/" class="home-feature-card group pop bg-accent-soft p-5">
      <h2 class="font-display text-2xl font-bold lowercase group-hover:text-accent transition-colors">rabbit holes<span class="text-accent">.</span></h2>
      <p class="mt-2 text-sm text-ink-soft leading-relaxed">
        Strange stories, historical detours, and big questions that earn the class period.
      </p>
      <span class="mt-3 inline-block text-accent transition-transform group-hover:translate-x-1.5">→</span>
    </a>
    <a href="/tools/" class="home-feature-card group pop bg-ink p-5 text-paper">
      <h2 class="font-display text-2xl font-bold lowercase">tools<span class="text-accent">.</span></h2>
      <p class="mt-2 text-sm text-paper/70 leading-relaxed">
        Timer, group maker, cold-call picker, dice, scoreboard. The stuff that keeps class moving.
      </p>
      <span class="mt-3 inline-block text-accent transition-transform group-hover:translate-x-1.5">→</span>
    </a>
  </section>

  <!-- latest announcements -->
  <section id="today" class="mt-20 scroll-mt-32">
    <div class="flex items-baseline justify-between">
      <h2 class="font-display text-3xl font-bold lowercase">on the desk right now</h2>
      <a href="/announcements/" class="text-sm text-accent hover:text-accent-dark lowercase">all announcements →</a>
    </div>
    <ul class="mt-6 space-y-3">
      {
        announcements.map((a) => (
          <li class="flex gap-4 items-baseline border-b-2 border-line pb-3">
            <span class="font-mono text-xs bg-accent-soft text-accent-dark px-2 py-0.5 shrink-0">
              {dateFmt.format(a.data.date)}
            </span>
            <div>
              <span class="font-semibold">{a.data.title}</span>
              {a.data.course && <span class="ml-2 text-xs font-mono lowercase text-accent">{a.data.course}</span>}
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</Base>

<style>
  .home-library {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink) 16%, transparent);
    border-radius: 1.15rem;
    background:
      linear-gradient(130deg, color-mix(in srgb, var(--color-accent-soft) 52%, white), white 42%),
      white;
    box-shadow: 0 26px 58px -48px rgb(23 23 28 / 0.8);
  }

  .home-library::before {
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent), color-mix(in srgb, var(--color-accent) 20%, transparent) 64%, transparent);
    content: '';
  }

  .home-course-card {
    --course-accent: var(--color-accent);
    --course-soft: var(--color-accent-soft);
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: 17rem;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink) 15%, transparent);
    border-radius: 1.05rem;
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--course-soft) 58%, white), white 52%),
      white;
    box-shadow: 0 22px 50px -44px rgb(23 23 28 / 0.75);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .home-course-card::before {
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--course-accent), color-mix(in srgb, var(--course-accent) 16%, transparent) 75%, transparent);
    content: '';
  }

  .home-course-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--course-accent) 48%, transparent);
    box-shadow: 0 30px 60px -44px color-mix(in srgb, var(--course-accent) 34%, transparent);
  }

  .home-course-card[data-course='history'] {
    --course-accent: #a63a2f;
    --course-soft: #fff0ed;
  }

  .home-course-card[data-course='classified'] {
    --course-accent: #8a6100;
    --course-soft: #fff6ce;
  }

  .home-course-card[data-course='scoreboard'] {
    --course-accent: #08765a;
    --course-soft: #e4fff5;
  }

  .home-course-card__ghost {
    position: absolute;
    z-index: -1;
    right: -0.15rem;
    bottom: -1.4rem;
    color: color-mix(in srgb, var(--course-accent) 7%, transparent);
    font-family: var(--font-display);
    font-size: 8rem;
    font-weight: 700;
    letter-spacing: -0.1em;
    line-height: 1;
  }

  .home-course-card__identity {
    color: color-mix(in srgb, var(--course-accent) 88%, var(--color-ink));
    font-family: var(--font-mono);
    font-size: 0.61rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .home-course-card__title {
    margin-top: 0.8rem;
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.02;
    text-transform: lowercase;
  }

  .home-course-card__title span {
    color: var(--course-accent);
  }

  .home-course-card__blurb {
    position: relative;
    margin-top: 0.75rem;
    color: var(--color-ink-soft);
    font-size: 0.84rem;
    line-height: 1.6;
  }

  .home-course-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 1.2rem;
    color: color-mix(in srgb, var(--course-accent) 88%, var(--color-ink));
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: lowercase;
  }

  .home-course-card__cta span {
    transition: transform 180ms ease;
  }

  .home-course-card:hover .home-course-card__cta span {
    transform: translateX(0.25rem);
  }

  .home-feature-card {
    min-height: 10rem;
    border-radius: 1rem;
  }
</style>
