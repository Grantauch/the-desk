---

<Base title="rabbit holes">
  <h1 class="font-display text-5xl sm:text-6xl font-bold lowercase tracking-tight">
    rabbit holes<span class="text-accent">.</span>
  </h1>
  <p class="mt-3 text-lg text-ink-soft lowercase">
    the stories too good to leave in the margins.
  </p>

  <div class="mt-10 space-y-8">
    {
      decks.map((deck) => (
        <article class="pop rounded-md bg-white p-6">
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <h2 class="font-display text-2xl font-bold lowercase">
              <a href={deck.href} target="_blank" rel="noopener" class="hover:text-accent transition-colors">
                {deck.name} →
              </a>
            </h2>
            <span class="text-xs font-mono lowercase text-accent">{deck.tag}</span>
          </div>
          <p class="mt-3 leading-relaxed text-ink-soft">{deck.blurb}</p>
        </article>
      ))
    }
  </div>

  <p class="mt-10 text-sm font-mono lowercase text-ink-soft">
    one good question usually causes three more.
  </p>
</Base>
