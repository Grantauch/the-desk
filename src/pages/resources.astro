---
// resources.astro — the searchable front end for the Drive resource inventory.
// The data is generated from the-desk-resource-inventory.xlsx and lives in
// src/data/resources.json so every resource has one shared source on the site.
import resourceLibrary from '../data/resources.json';
import Base from '../layouts/Base.astro';

interface Resource {
  id: string;
  course: string;
  unitTopic: string;
  name: string;
  type: string;
  onWebsite: boolean;
  href: string | null;
}

const library = resourceLibrary as {
  resourceCount: number;
  linkedCount: number;
  resources: Resource[];
};

const preferredCourseOrder = [
  'US History',
  'Hidden History',
  'Beyond the Scoreboard',
  'Economics',
  'Government / Civics',
  'Law',
  'World History',
  'Personal Finance',
  'Rabbit Holes',
  'Both Electives',
  'Other / Misc',
];
const courseRank = new Map(preferredCourseOrder.map((course, index) => [course, index]));
const courses = [...new Set(library.resources.map((resource) => resource.course))].sort(
  (a, b) =>
    (courseRank.get(a) ?? preferredCourseOrder.length) -
      (courseRank.get(b) ?? preferredCourseOrder.length) || a.localeCompare(b),
);
const types = [...new Set(library.resources.map((resource) => resource.type))].sort((a, b) =>
  a.localeCompare(b),
);
const courseGroups = courses.map((course) => ({
  course,
  resources: library.resources
    .filter((resource) => resource.course === course)
    .sort(
      (a, b) =>
        a.unitTopic.localeCompare(b.unitTopic, 'en', { sensitivity: 'base' }) ||
        a.name.localeCompare(b.name, 'en', { sensitivity: 'base' }),
    ),
}));
const activeCourseNames = ['US History', 'Hidden History', 'Beyond the Scoreboard'];
const activeCourses = activeCourseNames.map((course) => ({
  course,
  count: library.resources.filter((resource) => resource.course === course).length,
}));
const unlinkedCount = library.resourceCount - library.linkedCount;
---

<Base
  title="resource library"
  description="Browse the desk's complete teaching-resource library by course, topic, and resource type."
>
  <section class="dot-grid -mx-5 px-5 pb-10">
    <p class="font-mono text-sm lowercase text-accent">
      {library.resourceCount} resources · {library.linkedCount} ready to open
    </p>
    <h1 class="mt-2 font-display text-5xl sm:text-6xl font-bold lowercase tracking-tight">
      resource library<span class="text-accent">.</span>
    </h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-soft lowercase">
      the whole teaching archive, finally findable. search a title, pick a class, or browse the stacks.
    </p>
  </section>

  <section class="pop rounded-md bg-white p-5 sm:p-6" aria-label="Resource filters">
    <div class="mb-5 border-b border-line pb-5">
      <p class="font-mono text-xs font-semibold lowercase text-accent">teaching now</p>
      <nav class="mt-2 flex flex-wrap gap-2" aria-label="Current course libraries">
        {
          activeCourses.map(({ course, count }) => (
            <a
              href={`/resources/?course=${encodeURIComponent(course)}`}
              class="rounded-md border-2 border-ink bg-paper px-3 py-1.5 font-mono text-xs font-semibold lowercase transition-colors hover:border-accent hover:text-accent"
            >
              {course} · {count}
            </a>
          ))
        }
      </nav>
      <p class="mt-3 text-sm leading-relaxed text-ink-soft lowercase">
        current-course drive materials open with your mtmorrisschools.org google account.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr]">
      <label class="block">
        <span class="font-mono text-xs font-semibold lowercase text-ink-soft">search</span>
        <input
          id="resource-search"
          type="search"
          autocomplete="off"
          placeholder="try: cold war, taxes, roswell…"
          class="mt-1.5 w-full rounded-md border-2 border-ink bg-paper px-3 py-2.5 text-base outline-none transition-colors focus:border-accent"
        />
      </label>

      <label class="block">
        <span class="font-mono text-xs font-semibold lowercase text-ink-soft">course</span>
        <select
          id="course-filter"
          class="mt-1.5 w-full rounded-md border-2 border-ink bg-paper px-3 py-2.5 text-base outline-none transition-colors focus:border-accent"
        >
          <option value="">all courses</option>
          {courses.map((course) => <option value={course}>{course}</option>)}
        </select>
      </label>

      <label class="block">
        <span class="font-mono text-xs font-semibold lowercase text-ink-soft">type</span>
        <select
          id="type-filter"
          class="mt-1.5 w-full rounded-md border-2 border-ink bg-paper px-3 py-2.5 text-base outline-none transition-colors focus:border-accent"
        >
          <option value="">all types</option>
          {types.map((type) => <option value={type}>{type}</option>)}
        </select>
      </label>
    </div>

    <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-4">
      <p class="font-mono text-sm lowercase text-ink-soft" aria-live="polite">
        <span id="result-count" class="font-bold text-ink">{library.resourceCount}</span> resources showing
      </p>
      <button
        id="clear-filters"
        type="button"
        class="rounded-md border-2 border-ink px-3 py-1.5 font-mono text-xs font-semibold lowercase transition-colors hover:border-accent hover:text-accent"
      >
        clear filters
      </button>
    </div>

    <noscript>
      <p class="mt-4 text-sm text-ink-soft">Search needs JavaScript, but every course can still be opened below.</p>
    </noscript>
  </section>

  <div id="resource-groups" class="mt-10 space-y-5">
    {
      courseGroups.map((group) => (
        <details data-resource-group class="pop rounded-md bg-white">
          <summary class="cursor-pointer px-5 py-4 marker:text-accent sm:px-6">
            <span class="ml-2 inline-flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <span class="font-display text-xl font-bold lowercase sm:text-2xl">{group.course}</span>
              <span class="font-mono text-xs lowercase text-ink-soft">
                <span data-visible-count>{group.resources.length}</span> resources
              </span>
            </span>
          </summary>

          <div class="border-t-2 border-ink px-5 py-5 sm:px-6">
            <div class="grid gap-4 sm:grid-cols-2">
              {group.resources.map((resource) => (
                <article
                  id={resource.id}
                  data-resource-card
                  data-course={resource.course}
                  data-type={resource.type}
                  data-search={`${resource.name} ${resource.course} ${resource.unitTopic} ${resource.type}`.toLocaleLowerCase(
                    'en',
                  )}
                  class="rounded-md border-2 border-line bg-paper p-4 transition-colors hover:border-ink"
                >
                  <div class="flex flex-wrap items-center gap-2 font-mono text-[0.7rem] lowercase">
                    <span class="font-semibold text-accent">{resource.type}</span>
                    <span class="text-ink-soft">· {resource.unitTopic}</span>
                  </div>
                  <h2 class="mt-2 font-display text-lg font-bold leading-snug">{resource.name}</h2>
                  <div class="mt-4">
                    {resource.href ? (
                      <a
                        href={resource.href}
                        target="_blank"
                        rel="noopener"
                        class="font-mono text-xs font-semibold lowercase text-accent hover:text-accent-dark"
                      >
                        open in drive ↗
                      </a>
                    ) : (
                      <span class="font-mono text-xs lowercase text-ink-soft">link coming soon</span>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </details>
      ))
    }
  </div>

  <p id="no-results" class="pop mt-10 rounded-md bg-white p-6 text-center text-ink-soft" hidden>
    nothing matched. try a broader search or clear the filters.
  </p>

  <p class="mt-10 font-mono text-xs lowercase leading-relaxed text-ink-soft">
    {library.linkedCount} resources are ready to open. {unlinkedCount} are catalogued while their links are being matched.
    nothing searched here is saved or sent anywhere.
  </p>

  <script>
    const searchInput = document.querySelector<HTMLInputElement>('#resource-search');
    const courseFilter = document.querySelector<HTMLSelectElement>('#course-filter');
    const typeFilter = document.querySelector<HTMLSelectElement>('#type-filter');
    const clearButton = document.querySelector<HTMLButtonElement>('#clear-filters');
    const resultCount = document.querySelector<HTMLElement>('#result-count');
    const noResults = document.querySelector<HTMLElement>('#no-results');
    const cards = [...document.querySelectorAll<HTMLElement>('[data-resource-card]')];
    const groups = [...document.querySelectorAll<HTMLDetailsElement>('[data-resource-group]')];

    const applyFilters = () => {
      const searchTerm = searchInput?.value.trim().toLocaleLowerCase('en') ?? '';
      const selectedCourse = courseFilter?.value ?? '';
      const selectedType = typeFilter?.value ?? '';
      const filtersActive = Boolean(searchTerm || selectedCourse || selectedType);
      let visibleTotal = 0;

      cards.forEach((card) => {
        const matchesSearch = !searchTerm || card.dataset.search?.includes(searchTerm);
        const matchesCourse = !selectedCourse || card.dataset.course === selectedCourse;
        const matchesType = !selectedType || card.dataset.type === selectedType;
        const isVisible = Boolean(matchesSearch && matchesCourse && matchesType);
        card.hidden = !isVisible;
        if (isVisible) visibleTotal += 1;
      });

      groups.forEach((group) => {
        const visibleInGroup = [...group.querySelectorAll<HTMLElement>('[data-resource-card]')].filter(
          (card) => !card.hidden,
        ).length;
        group.hidden = visibleInGroup === 0;
        if (filtersActive && visibleInGroup > 0) group.open = true;
        const groupCount = group.querySelector<HTMLElement>('[data-visible-count]');
        if (groupCount) groupCount.textContent = String(visibleInGroup);
      });

      if (resultCount) resultCount.textContent = String(visibleTotal);
      if (noResults) noResults.hidden = visibleTotal !== 0;
    };

    const params = new URLSearchParams(window.location.search);
    const initialSearch = params.get('q');
    const initialCourse = params.get('course');
    const initialType = params.get('type');
    const hasOption = (select: HTMLSelectElement | null, value: string | null) =>
      Boolean(value && select && [...select.options].some((option) => option.value === value));

    if (searchInput && initialSearch) searchInput.value = initialSearch;
    if (hasOption(courseFilter, initialCourse)) courseFilter!.value = initialCourse!;
    if (hasOption(typeFilter, initialType)) typeFilter!.value = initialType!;
    applyFilters();

    searchInput?.addEventListener('input', applyFilters);
    courseFilter?.addEventListener('change', applyFilters);
    typeFilter?.addEventListener('change', applyFilters);
    clearButton?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      if (courseFilter) courseFilter.value = '';
      if (typeFilter) typeFilter.value = '';
      groups.forEach((group) => (group.open = false));
      applyFilters();
      searchInput?.focus();
    });
  </script>
</Base>
