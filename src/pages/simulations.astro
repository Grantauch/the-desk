---
// simulations.astro — the showcase page for classroom games and simulations.
// Edit the `sims` array to add, remove, or update entries.
// `details` is optional — each {heading, items} pair becomes an expandable section.
import Base from '../layouts/Base.astro';

const sims = [
  {
    name: 'the stock market game',
    course: 'economics',
    status: 'runs every spring',
    blurb:
      'Every student manages a live (paper) portfolio for the length of the unit. Daily standings, real market data, and a leaderboard nobody stops checking. Past champions are remembered. Past crashes are, too.',
    details: [
      {
        heading: 'how it works',
        items: [
          'Everyone starts with the same imaginary bankroll. What you do with it is up to you.',
          'Trades execute at real market prices. The market does not know you have a quiz Friday and does not care.',
          'Standings post daily. Trash talk is permitted; insider trading is not (also, you have no inside).',
          'You keep a trade journal — every buy and sell needs a reason written before you make it.',
          'Final reckoning: portfolios are judged on returns and on the quality of the reasoning. A lucky gambler can outscore the market and still lose the write-up.',
        ],
      },
      {
        heading: 'the fine print',
        items: [
          'No options, no crypto, no meme-stock all-ins after the first cautionary tale.',
          'Diversification is not required by the rules. It is required by experience.',
        ],
      },
    ],
  },
  {
    name: 'behavioral econ lab',
    course: 'economics',
    status: 'ongoing',
    blurb:
      'Auctions, ultimatum games, and framing experiments — run on the class itself. We generate the data, then figure out why we all fell for it.',
    details: [
      {
        heading: 'experiments we run',
        items: [
          'The anchoring auction: two groups, two starting numbers, wildly different bids for the same object.',
          'The ultimatum game: free money gets rejected out of spite, every single time.',
          'Framing flips: the same choice, worded two ways, and the room splits.',
          'Loss aversion trades: what people demand to give something up vs. pay to get it.',
          'The results go on the board with your (anonymous) data in them. You are the study.',
        ],
      },
    ],
  },
  {
    name: 'mock trial',
    course: 'law',
    status: 'end of year',
    blurb:
      'A full trial with attorneys, witnesses, and a jury. Real rules of evidence, real objections, real verdict. The gavel is not decorative.',
    details: [
      {
        heading: 'the roles',
        items: [
          'Attorneys — openings, examinations, closings. You will be on your feet and you will be interrupted.',
          'Witnesses — you get a statement and you stick to it. Improvisation is how cases die.',
          'Jurors — you decide the verdict and defend it in deliberation. No pressure.',
          'Bailiff & clerk — the trial runs on time because of you.',
        ],
      },
      {
        heading: 'objection cheat sheet',
        items: [
          'Hearsay — the witness is repeating an out-of-court statement to prove it’s true.',
          'Leading — counsel is putting words in the witness’s mouth on direct. ("You were home that night, weren’t you?")',
          'Relevance — interesting, maybe. Related to this case, no.',
          'Speculation — the witness is guessing about things they didn’t see or can’t know.',
          'Badgering — counsel is arguing with the witness instead of questioning them.',
          'Asked and answered — moving on. The jury heard it the first time.',
          'When in doubt: stand, say "objection," name the reason. The judge will do the rest.',
        ],
      },
    ],
  },
  {
    name: 'constitutional convention',
    course: 'us history',
    status: 'fall semester',
    blurb:
      'Delegates, factions, and compromises — the room where it happened, recreated. Sectional interests included at no extra charge.',
    details: [
      {
        heading: 'how it works',
        items: [
          'You draw a delegate — a real one, with real interests. Virginia planters and Connecticut merchants do not want the same country.',
          'Committees draft, the floor debates, and everything needs votes to pass.',
          'Representation, slavery, executive power — the actual sticking points, argued from your delegate’s chair, not yours.',
          'The class constitution gets signed (or doesn’t) on the last day, then measured against the real one.',
          'History grades you on a curve here: the real convention nearly fell apart too.',
        ],
      },
    ],
  },
];
---

<Base title="simulations">
  <h1 class="font-display text-5xl sm:text-6xl font-bold lowercase tracking-tight">
    simulations<span class="text-accent">.</span>
  </h1>
  <p class="mt-3 text-lg text-ink-soft lowercase">where the class stops taking notes and starts playing for keeps.</p>

  <div class="mt-10 space-y-8">
    {
      sims.map((sim) => (
        <article class="pop rounded-md bg-white p-6">
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <h2 class="font-display text-2xl font-bold lowercase">{sim.name}</h2>
            <span class="text-xs font-mono lowercase text-accent">{sim.course}</span>
            <span class="text-xs font-mono lowercase text-ink-soft">· {sim.status}</span>
          </div>
          <p class="mt-3 leading-relaxed text-ink-soft">{sim.blurb}</p>
          {sim.details &&
            sim.details.map((section) => (
              <details class="mt-4 group">
                <summary class="cursor-pointer font-mono text-sm lowercase text-accent hover:text-accent-dark select-none">
                  <span class="group-open:hidden">{section.heading} +</span>
                  <span class="hidden group-open:inline">{section.heading} −</span>
                </summary>
                <ul class="mt-3 space-y-2 text-sm text-ink-soft leading-relaxed">
                  {section.items.map((item) => (
                    <li class="flex gap-2.5">
                      <span class="text-accent shrink-0">·</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </details>
            ))}
        </article>
      ))
    }
  </div>
</Base>
