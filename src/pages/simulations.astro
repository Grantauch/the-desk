---
// simulations.astro — the showcase page for classroom games and simulations.
// Edit the `sims` array to add, remove, or update entries.
// `details` is optional — each {heading, items} pair becomes an expandable section.
import Base from '../layouts/Base.astro';

const sims = [
  {
    name: 'the case file',
    course: 'hidden history',
    status: 'semester capstone',
    links: [
      { label: 'student organizer pack', href: 'https://docs.google.com/document/d/1fgFs8thNR-9nty8G-v7CK5qv2_kieaMPY8u57eGZi28/edit' },
      { label: 'station sheets & claim cards', href: 'https://docs.google.com/document/d/1-IBhlpcTMofvfwFthAYZelwl9H4FGULBCL9EQoqfclk/edit' },
    ],
    blurb:
      'Pick an approved claim, investigate it, and defend your verdict in front of the class. Confirmed, debunked, misleading, or unproven—the point is how you got there.',
    details: [
      {
        heading: 'how it works',
        items: [
          'You draw from the approved claim list — each one has real sources to find and a trap built in.',
          'Every claim breaks into sub-claims. You run each one to ground separately, with a source log.',
          'Your verdict must be earned: reliable documents, corroboration, and an honest account of what you couldn’t confirm.',
          'Presentations run in verdict order: confirmed first, debunked second, unproven last.',
          'An honest "unproven" backed by good research beats a confident answer backed by nothing. House rule.',
        ],
      },
      {
        heading: 'the fine print',
        items: [
          'Any factual claim in your presentation can be challenged from the floor.',
          'We attack claims, never people. Discovering your own belief doesn’t survive the evidence counts as a win.',
        ],
      },
    ],
  },
  {
    name: 'the surveillance debate',
    course: 'hidden history',
    status: 'unit 5',
    links: [
      { label: 'debate brief', href: 'https://docs.google.com/document/d/1H_Hu8LlUEuLwaI0fp5Gqz7oyV2_3pTOiINltfQeqHl0/view' },
      { label: 'unit 5 source packet', href: 'https://docs.google.com/document/d/1iXsBKdU0cHwKZho0X23RiyT135AjZfM7OdTUtMK-YlM/view' },
    ],
    blurb:
      'COINTELPRO is documented. So is the Church Committee that exposed it. Now the class argues the line: how much watching is too much — and who watches the watchers?',
    details: [
      {
        heading: 'how it works',
        items: [
          'Structured format: opening cases, cross-examination, and closing arguments, with assigned sides.',
          'Every factual claim needs a source you can produce on demand — including the teacher’s.',
          'You argue the side you draw, not the side you like. Knowing the other side’s best case is the point.',
          'The audience scores arguments on evidence, not volume.',
        ],
      },
    ],
  },
  {
    name: 'the mkultra hearing',
    course: 'hidden history',
    status: 'unit 4',
    links: [
      { label: 'hearing source packet', href: 'https://docs.google.com/document/d/1dhPGLZzz0hmPbZ1PuaAyztZX1ovTqBzrkjujvCoYBCA/view' },
      { label: 'launch & hearing mini-packet', href: 'https://docs.google.com/document/d/1-pc2ewld9Q6-Ec3bbuaYapqRzRXfY3eBZT7e8QSvXxg/view' },
    ],
    blurb:
      'A 2026 congressional hearing, fifty years late: witnesses, counsel, and committee members re-open the MKUltra file. Everything in the packet is real — that\'s what makes the hearing work.',
    details: [
      {
        heading: 'how it works',
        items: [
          'Roles are drawn: committee members, witnesses, counsel, and the press gallery.',
          'Every question and answer must trace to a document in the source packet.',
          'The destroyed-files problem is part of the exercise: what can you still prove, and what is honestly unprovable?',
          'The committee issues findings using the four verdicts — on the record.',
        ],
      },
    ],
  },
  {
    name: 'the michigan capstone',
    course: 'beyond the scoreboard',
    status: 'end of semester',
    links: [
      { label: 'organizers, capstone & rubrics', href: 'https://docs.google.com/document/d/1f81B7HS1ZqcnBpaZ2tM7wkDbBs3_s-1tXblK4d9fdfw/edit' },
    ],
    blurb:
      'A team research project on a sports story from Michigan’s backyard — Joe Louis, Hank Greenberg, the Malice at the Palace, Claressa Shields, or one you pitch yourself. Real sources, real stakes, local ground.',
    details: [
      {
        heading: 'how it works',
        items: [
          'Teams pick a Michigan sports story and trace it through all four course threads: business, media, law, and who gets to play.',
          'Primary sources required — newspapers of the day, broadcast footage, court records, the stuff historians actually use.',
          'The deliverable: a documented case for what your story says about America, presented to the class.',
          'Pitching your own story is encouraged. Michigan has more of them than the syllabus can hold.',
        ],
      },
    ],
  },
  {
    name: 'socratic seminars',
    course: 'both classes',
    status: 'every unit',
    links: [
      { label: 'seminar prep sheet', href: 'https://docs.google.com/document/d/1jM5TPMrQ1IRuMWYRCthb2qpiAhEiFwYmFNPnyN5lObo/edit' },
    ],
    blurb:
      'A discussion where the evidence sits in the middle of the room and everyone comes armed with a prep ticket. The quietest well-sourced argument beats the loudest unsourced one.',
    details: [
      {
        heading: 'the rules',
        items: [
          'Entry requires a completed seminar ticket — your claims, your sources, your questions.',
          'Build on, push back, or redirect — but address the argument, not the person who made it.',
          '"What’s your source?" is always in bounds. For everyone. Including the teacher.',
          'Use the unit’s vocabulary when it actually helps the argument.',
        ],
      },
    ],
  },
];
---

<Base title="simulations">
  <h1 class="font-display text-5xl sm:text-6xl font-bold lowercase tracking-tight">
    simulations<span class="text-accent">.</span>
  </h1>
  <p class="mt-3 text-lg text-ink-soft lowercase">the days class gets loud on purpose.</p>

  <div class="mt-10 space-y-8">
    {
      sims.map((sim) => (
        <article class="pop rounded-md bg-white p-6">
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <h2 class="font-display text-2xl font-bold lowercase">{sim.name}</h2>
            <span class="text-xs font-mono lowercase text-accent">{sim.course}</span>
            <span class="text-xs font-mono lowercase text-ink-soft">· {sim.status}</span>
          </div>
          <p class="mt-3 leading-relaxed text-ink-soft">{sim.blurb}</p>
          {sim.details &&
            sim.details.map((section) => (
              <details class="mt-4 group">
                <summary class="cursor-pointer font-mono text-sm lowercase text-accent hover:text-accent-dark select-none">
                  <span class="group-open:hidden">{section.heading} +</span>
                  <span class="hidden group-open:inline">{section.heading} −</span>
                </summary>
                <ul class="mt-3 space-y-2 text-sm text-ink-soft leading-relaxed">
                  {section.items.map((item) => (
                    <li class="flex gap-2.5">
                      <span class="text-accent shrink-0">·</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </details>
            ))}
          {sim.links && (
            <div class="mt-4 flex flex-wrap gap-2">
              {sim.links.map((l) => (
                <a
                  href={l.href}
                  target="_blank"
                  rel="noopener"
                  class="font-mono text-xs lowercase border-2 border-ink px-3 py-1.5 hover:bg-accent hover:text-white hover:border-accent transition-colors"
                >
                  {l.label} ↗
                </a>
              ))}
            </div>
          )}
        </article>
      ))
    }
  </div>
</Base>
