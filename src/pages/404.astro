---
// 404.astro — shown by Netlify for any page that doesn't exist.
import Base from '../layouts/Base.astro';
---

<Base title="404">
  <section class="py-16 dot-grid">
    <p class="font-mono text-xs lowercase text-accent">case file: error 404</p>
    <h1 class="mt-3 font-display text-6xl sm:text-7xl font-bold lowercase tracking-tight">
      unproven<span class="text-accent">.</span>
    </h1>
    <p class="mt-5 text-lg text-ink-soft max-w-xl">
      You've made a claim: that a page exists at this address. We've checked the record — no documents, no witnesses,
      no corroboration. The available evidence is insufficient either way, and an honest "unproven" beats a confident
      answer backed by nothing. Investigate somewhere real:
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/" class="pop-ink bg-accent text-white font-mono lowercase px-5 py-2">back to the desk</a>
      <a href="/games/" class="font-mono lowercase border-2 border-ink px-5 py-2 hover:bg-ink hover:text-paper transition-colors">games</a>
      <a href="/announcements/" class="font-mono lowercase border-2 border-ink px-5 py-2 hover:bg-ink hover:text-paper transition-colors">announcements</a>
    </div>
    <p class="mt-8 font-mono text-xs lowercase text-ink-soft">sources or it didn't happen. — hidden history, rule 2</p>
  </section>
</Base>
