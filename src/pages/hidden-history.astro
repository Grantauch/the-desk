const resources = [
  { label: 'Google Classroom', href: 'https://classroom.google.com' },
  { label: 'National Security Archive — declassified documents', href: 'https://nsarchive.gwu.edu' },
  { label: 'National Archives — JFK assassination records', href: 'https://www.archives.gov/research/jfk' },
