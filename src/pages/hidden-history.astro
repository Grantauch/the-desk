const glossary = [
  { term: 'primary source', def: 'Evidence from the time itself — a memo, a photo, a tape, a front page. The raw material of every verdict in this class.' },
  { term: 'corroboration', def: 'A second, independent source saying the same thing. One document is a claim; two unrelated ones are the start of a case.' },
  { term: 'declassified', def: 'Officially released from secrecy by the government. Proves the document is real — not that every word in it is true.' },
  { term: 'redaction', def: 'The black bars. What’s hidden can matter as much as what’s shown — but a redaction is a blank, not a confession.' },
  { term: 'foia', def: 'The Freedom of Information Act — the law that lets anyone request government records. Slow, imperfect, and responsible for half the documents in this course.' },
  { term: 'misinformation', def: 'False information spread by people who believe it. Wrong, but sincere.' },
  { term: 'disinformation', def: 'False information spread by people who know better. Wrong, on purpose.' },
  { term: 'confirmation bias', def: 'The pull toward evidence that agrees with you. Nobody is immune, including historians. The fix is method, not willpower.' },
  { term: 'burden of proof', def: 'The claim-maker owes the evidence. "Prove it didn’t happen" is not how history — or this class — works.' },
  { term: 'whistleblower', def: 'An insider who exposes wrongdoing with documents and testimony. The difference between a whistleblower and a rumor is the receipts.' },
  { term: 'cover-up', def: 'A documented effort to hide the truth — which is exactly why it can be proven. Real cover-ups leave paper trails; imagined ones only leave vibes.' },
  { term: 'unproven', def: 'The most honest verdict in the deck: not enough reliable evidence either way. Saying it well is a skill; saying it backed by research is a grade.' },
  { term: 'falsifiability', def: 'A claim you could at least imagine disproving with evidence. If no possible discovery could ever count against it, it isn’t a theory — it’s a belief wearing a lab coat.' },
  { term: 'occam’s razor', def: 'When two explanations fit the evidence, the one requiring fewer moving parts usually wins. Not a law — a starting bet.' },
  { term: 'apophenia', def: 'The human talent for seeing patterns that aren’t there — faces in clouds, clues in album covers. Your brain does this constantly. This class is the countermeasure.' },
  { term: 'motivated reasoning', def: 'Working backward from the conclusion you want to the evidence that gets you there. Everyone does it; investigators build methods specifically to catch themselves.' },
  { term: 'the two-source rule', def: 'Woodward and Bernstein’s standard: no claim runs on a single source. One document can lie or err; two independent ones have to coordinate.' },
  { term: 'lateral reading', def: 'Fact-checking a source by leaving it — opening new tabs to see what others say about it, instead of judging its own polish. How professionals do it, and faster than it sounds.' },
  { term: 'hindsight bias', def: 'The past looks obvious once you know the ending — that’s why Pearl Harbor "warnings" seem so loud now and were whispers then. Judge decisions by what was knowable at the time.' },
  { term: 'cover story', def: 'The explanation issued to hide the real one — Roswell’s "weather balloon," Camp Century’s "research station." Real cover stories exist; that’s exactly why claims of them need evidence.' },
];
---

<CoursePage
  title="hidden history"
  tagline="coverups, conspiracies, and the evidence. sources or it didn't happen."
  intro="Some official stories collapsed under the evidence — Watergate, MKUltra, COINTELPRO. Some famous rumors did too. This class is about telling the difference. Every claim we study gets one of four verdicts — confirmed, debunked, misleading, or unproven — and you'll be graded on how you got there, not just where you landed. An honest 'unproven' backed by good research beats a confident answer backed by nothing."
  units={units}
  resources={resources}
  glossary={glossary}
>
  <section class="mt-12">
    <h2 class="font-display text-3xl font-bold lowercase">the daily desk<span class="text-accent">.</span></h2>
    <p class="mt-2 text-sm text-ink-soft lowercase">new every day. yes, you may fact-check it — that's the point.</p>
    <div class="mt-6 grid gap-6 md:grid-cols-2">
      <DailyCard label="verdict of the day" entries={verdicts} />
      <DailyCard label="declassified file of the day" entries={files} />
      <DailyCard label="trick of the week" entries={tricks} />
      <DailyCard label="argue this" entries={argueThis} />
    </div>
  </section>
</CoursePage>
