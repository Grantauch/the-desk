const exhibits = [
  { tag: 'fdr, first inaugural — 1933', text: '"The only thing we have to fear is fear itself." Banks were failing by the thousands that week. The line was a policy argument, not a pep talk.' },
  { tag: 'fdr to congress — december 8, 1941', text: '"A date which will live in infamy." The draft said "world history." FDR crossed it out and wrote "infamy" — better word, better speech.' },
  { tag: 'lincoln, second inaugural — 1865', text: '"With malice toward none, with charity for all." Six weeks later he was dead, and Reconstruction had to be run by men who believed in plenty of malice.' },
  { tag: 'lincoln, gettysburg — 1863', text: '"Four score and seven years ago." 272 words, about two minutes. The featured speaker that day went for two hours; nobody quotes him.' },
  { tag: 'theodore roosevelt — 1901', text: '"Speak softly and carry a big stick." He said it was a West African proverb. Nobody has ever found the proverb. The aircraft carriers were easier to verify.' },
  { tag: 'jfk, inaugural — 1961', text: '"Ask not what your country can do for you — ask what you can do for your country." The whole speech is 1,366 words. Brevity is a strategy.' },
  { tag: 'mlk, march on washington — 1963', text: '"I have a dream." The best-remembered section wasn’t in the prepared text — gospel singer Mahalia Jackson called out "Tell them about the dream," and King pushed his notes aside.' },
  { tag: 'malcolm x, cleveland — 1964', text: '"The ballot or the bullet." A voting-rights speech, despite the title — his argument was that 1964 had to be the year of the ballot, precisely so it wouldn’t be the other thing.' },
  { tag: 'reagan, berlin — 1987', text: '"Mr. Gorbachev, tear down this wall!" State Department drafts kept cutting the line as too provocative. Reagan kept putting it back. The wall outlasted the speech by 29 months.' },
  { tag: 'armstrong, the moon — 1969', text: '"That’s one small step for man, one giant leap for mankind." Armstrong insisted he said "for a man" and the radio ate the word. The tape is ambiguous. Even moon landings have primary-source problems.' },
