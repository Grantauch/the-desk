const glossary = [
  { term: 'primary source', def: 'Evidence from the time itself — a letter, a photo, a law, a receipt. The raw material of history, before anyone put a spin on it. (Everyone puts a spin on it.)' },
  { term: 'reconstruction', def: 'The post-Civil War project to rebuild the South and define freedom. Its amendments changed the Constitution; its retreat shaped the next century.' },
  { term: 'sharecropping', def: 'Farming someone else’s land for a share of the crop — and usually a growing debt. Freedom’s fine print in the postwar South.' },
  { term: 'jim crow', def: 'The legal system of racial segregation after Reconstruction — not custom, but law, enforced for generations.' },
  { term: 'gilded age', def: 'Mark Twain’s name for the late 1800s: gold on the surface, cheaper metal underneath. Railroads, fortunes, and the people who built both.' },
  { term: 'muckraker', def: 'An investigative journalist of the Progressive Era. Meant as an insult; taken as a job description.' },
  { term: 'great migration', def: 'Six million Black Americans leaving the South for northern and western cities across the twentieth century. Detroit is a chapter of this story.' },
  { term: 'new deal', def: 'FDR’s Depression-era program — relief, recovery, reform. We still argue about whether it worked, which is why it’s a unit and not a footnote.' },
  { term: 'containment', def: 'The Cold War strategy of stopping Soviet expansion without starting World War III. Simple to state, expensive to run.' },
  { term: 'civil disobedience', def: 'Deliberately, publicly, nonviolently breaking an unjust law and accepting the consequences. Thoreau theorized it; the Civil Rights Movement mastered it.' },
  { term: 'credibility gap', def: 'The distance between what officials said and what turned out to be true — Vietnam-era vocabulary that never went out of style.' },
  { term: 'redlining', def: 'Government-backed maps that graded neighborhoods by race and starved the red ones of loans. How segregation got built into cities — including ours.' },
];
