const resources = [
  { label: 'Google Classroom', href: 'https://classroom.google.com' },
  { label: 'Library of Congress — primary sources', href: 'https://www.loc.gov/classroom-materials/' },
  { label: 'National Archives — DocsTeach', href: 'https://www.docsteach.org' },
