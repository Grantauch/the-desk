---
interface HookOption {
  label: string;
  response: string;
}

interface Props {
  id: string;
  eyebrow: string;
  question: string;
  options: HookOption[];
}

const { id, eyebrow, question, options } = Astro.props;
const questionId = `${id}-question`;
const responseId = `${id}-response`;
---

<section class="quick-take rounded-md border-2 border-ink bg-white p-5 sm:p-6" data-quick-take aria-labelledby={questionId}>
  <p class="font-mono text-[0.68rem] font-bold uppercase tracking-[0.18em] text-accent">{eyebrow}</p>
  <h2 id={questionId} class="mt-2 max-w-2xl font-display text-2xl font-bold lowercase sm:text-3xl">{question}</h2>
  <div class="mt-5 flex flex-wrap gap-3" role="group" aria-label="Choose your first take">
    {
      options.map((option) => (
        <button
          type="button"
          class="quick-take__option rounded-full border-2 border-ink bg-white px-4 py-2 text-left font-mono text-xs font-bold lowercase transition-colors hover:bg-accent-soft focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          aria-pressed="false"
          aria-controls={responseId}
          data-response={option.response}
        >
          {option.label}
        </button>
      ))
    }
  </div>
  <p id={responseId} class="quick-take__response mt-5 hidden border-l-4 border-accent pl-4 text-sm leading-relaxed text-ink-soft" aria-live="polite"></p>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-quick-take]').forEach((quickTake) => {
    const buttons = Array.from(quickTake.querySelectorAll<HTMLButtonElement>('[data-response]'));
    const response = quickTake.querySelector<HTMLElement>('.quick-take__response');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        buttons.forEach((candidate) => candidate.setAttribute('aria-pressed', String(candidate === button)));
        if (!response) return;

        response.textContent = button.dataset.response ?? '';
        response.classList.remove('hidden');
      });
    });
  });
</script>

<style>
  .quick-take {
    box-shadow: 5px 5px 0 0 var(--color-accent);
  }

  .quick-take__option[aria-pressed='true'] {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: white;
  }
</style>
