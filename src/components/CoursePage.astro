---
// CoursePage.astro — shared template for class pages.
// Each class page (us-history, hidden-history, beyond-the-scoreboard) just passes in its data.
// Anything placed between <CoursePage>...</CoursePage> tags renders after the "right now" box.
import Base from '../layouts/Base.astro';

interface Unit {
  name: string;
  blurb: string;
  current?: boolean;
  topics?: string[]; // optional: shows a "what's inside" dropdown on the unit
  materials?: { label: string; href: string }[]; // optional: slides, packets, handouts for this unit
}

interface Resource {
  label: string;
  href: string;
}

interface GlossaryEntry {
  term: string;
  def: string;
}

interface Props {
  title: string;
  tagline: string;
  intro: string;
  units: Unit[];
  resources: Resource[];
  glossary?: GlossaryEntry[]; // optional: adds a "words worth knowing" section
}

const { title, tagline, intro, units, resources, glossary = [] } = Astro.props;
const currentUnit = units.find((u) => u.current);
---

<Base title={title}>
  <h1 class="font-display text-5xl sm:text-6xl font-bold lowercase tracking-tight">
    {title}<span class="text-accent">.</span>
  </h1>
  <p class="mt-3 text-lg text-ink-soft lowercase">{tagline}</p>

  <p class="mt-6 max-w-2xl leading-relaxed">{intro}</p>

  {
    currentUnit && (
      <div class="pop-ink mt-10 rounded-md bg-accent text-white p-6">
        <p class="text-xs font-mono uppercase tracking-widest text-white/70">right now</p>
        <h2 class="mt-1 font-display text-2xl font-bold">{currentUnit.name}</h2>
        <p class="mt-1 text-white/85">{currentUnit.blurb}</p>
      </div>
    )
  }

  <slot />

  <h2 class="mt-14 font-display text-3xl font-bold lowercase">units</h2>
  <ol class="mt-6 space-y-3">
    {
      units.map((unit, i) => (
        <li class="flex gap-4 items-baseline border-b-2 border-line pb-3">
          <span class="font-display font-bold text-accent shrink-0">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <span class="font-semibold">{unit.name}</span>
            {unit.current && (
              <span class="ml-2 text-xs font-mono lowercase bg-accent text-white rounded-full px-2 py-0.5">
                current
              </span>
            )}
            <p class="text-sm text-ink-soft mt-0.5">{unit.blurb}</p>
            {unit.topics && unit.topics.length > 0 && (
              <details class="mt-1.5 group">
                <summary class="cursor-pointer text-xs font-mono lowercase text-accent hover:text-accent-dark select-none">
                  <span class="group-open:hidden">what's inside +</span>
                  <span class="hidden group-open:inline">what's inside −</span>
                </summary>
                <ul class="mt-2 mb-1 space-y-1 text-sm text-ink-soft">
                  {unit.topics.map((t) => (
                    <li class="flex gap-2">
                      <span class="text-accent">·</span>
                      <span>{t}</span>
                    </li>
                  ))}
                </ul>
              </details>
            )}
            {unit.materials && unit.materials.length > 0 && (
              <ul class="mt-2 flex flex-wrap gap-x-4 gap-y-1">
                {unit.materials.map((m) => (
                  <li>
                    <a
                      href={m.href}
                      target="_blank"
                      rel="noopener"
                      class="text-xs font-mono lowercase text-accent hover:text-accent-dark underline underline-offset-4"
                    >
                      {m.label} ↗
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </li>
      ))
    }
  </ol>

  {
    glossary.length > 0 && (
      <>
        <h2 class="mt-14 font-display text-3xl font-bold lowercase">words worth knowing</h2>
        <p class="mt-2 text-sm text-ink-soft">Click a term. Definitions in plain English, mostly.</p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {glossary.map((g) => (
            <details class="rounded-md border-2 border-line bg-white px-4 py-3 open:border-accent transition-colors">
              <summary class="cursor-pointer font-semibold lowercase select-none marker:text-accent">{g.term}</summary>
              <p class="mt-2 text-sm text-ink-soft leading-relaxed">{g.def}</p>
            </details>
          ))}
        </div>
      </>
    )
  }

  {
    resources.length > 0 && (
      <>
        <h2 class="mt-14 font-display text-3xl font-bold lowercase">resources</h2>
        <ul class="mt-4 space-y-2">
          {resources.map((r) => (
            <li>
              <a href={r.href} class="text-accent hover:text-accent-dark underline underline-offset-4">
                {r.label}
              </a>
            </li>
          ))}
        </ul>
      </>
    )
  }
</Base>
