---
// Shared template for the three active course pages.
import Base from '../layouts/Base.astro';

interface Unit {
  name: string;
  blurb: string;
  current?: boolean;
  topics?: string[];
  materials?: { label: string; href: string }[];
}

interface Resource {
  label: string;
  href: string;
}

interface GlossaryEntry {
  term: string;
  def: string;
}

interface CourseSecret {
  trigger: string;
  title: string;
  message: string;
}

interface Props {
  title: string;
  tagline: string;
  intro: string;
  units: Unit[];
  resources: Resource[];
  glossary?: GlossaryEntry[];
  theme?: 'history' | 'classified' | 'scoreboard';
  identityLabel?: string;
  secret?: CourseSecret;
}

const {
  title,
  tagline,
  intro,
  units,
  resources,
  glossary = [],
  theme = 'history',
  identityLabel,
  secret,
} = Astro.props;
const currentIndex = units.findIndex((unit) => unit.current);
const currentUnit = currentIndex >= 0 ? units[currentIndex] : undefined;
const hasHero = Astro.slots.has('hero');
const hasHook = Astro.slots.has('hook');
const secretId = `course-secret-${theme}`;
const courseMapCopy = {
  history: { status: 'archive position', current: 'current chapter', route: 'course chronology' },
  classified: { status: 'case status // active', current: 'active investigation', route: 'investigation route' },
  scoreboard: { status: 'game clock // running', current: 'now playing', route: 'season route' },
}[theme];
const progressPercent = currentIndex >= 0 ? ((currentIndex + 1) / units.length) * 100 : 0;
---

<Base title={title}>
  <div class:list={['course-page', `course-page--${theme}`]}>
    {identityLabel && <p class="font-mono text-[0.68rem] font-bold uppercase tracking-[0.2em] text-accent">{identityLabel}</p>}
    <h1 class:list={[identityLabel ? 'mt-3' : '', 'font-display text-5xl font-bold lowercase tracking-tight sm:text-6xl']}>
      {title}<span class="text-accent">.</span>
    </h1>
    <p class="mt-3 text-lg lowercase text-ink-soft">{tagline}</p>

    {hasHero && <slot name="hero" />}

    <p class:list={[hasHero ? 'mt-10' : 'mt-6', 'max-w-2xl leading-relaxed']}>{intro}</p>

    {hasHook && <div class="mt-10"><slot name="hook" /></div>}

    {
      currentUnit && (
        <section class="course-map mt-10" aria-labelledby="right-now-title">
          <header class="course-map__header">
            <p class="course-map__status">
              <span class="course-map__status-dot" aria-hidden="true"></span>
              {courseMapCopy.status}
            </p>
            <p class="course-map__count">
              <span>unit</span> {String(currentIndex + 1).padStart(2, '0')} <span>/</span> {String(units.length).padStart(2, '0')}
            </p>
          </header>

          <div class="course-map__layout">
            <div class="course-map__now">
              <span class="course-map__ghost-number" aria-hidden="true">{String(currentIndex + 1).padStart(2, '0')}</span>
              <p class="course-map__eyebrow">{courseMapCopy.current}</p>
              <h2 id="right-now-title" class="course-map__title">{currentUnit.name}</h2>
              <p class="course-map__blurb">{currentUnit.blurb}</p>
            </div>

            <div class="course-map__route">
              <p class="course-map__eyebrow">{courseMapCopy.route}</p>
              <ol class="course-map__units" aria-label={`Course progress: unit ${currentIndex + 1} of ${units.length}`}>
                {
                  units.map((unit, i) => (
                    <li
                      class="course-map__unit"
                      data-state={i < currentIndex ? 'complete' : i === currentIndex ? 'current' : 'upcoming'}
                      aria-current={i === currentIndex ? 'step' : undefined}
                    >
                      <span class="course-map__unit-number">{String(i + 1).padStart(2, '0')}</span>
                      <span class="course-map__unit-name">
                        {unit.name}
                        {i === currentIndex && <span class="sr-only"> (current)</span>}
                      </span>
                    </li>
                  ))
                }
              </ol>
            </div>
          </div>

          <footer class="course-map__footer">
            <div class="course-map__progress">
              <div class="course-map__progress-label">
                <span>position in course</span>
                <span>{Math.round(progressPercent)}%</span>
              </div>
              <div class="course-map__progress-track" aria-hidden="true">
                <span style={`width: ${progressPercent}%`}></span>
              </div>
            </div>

            {
              secret && (
                <div class="course-map__secret" data-course-secret>
                  <button
                    type="button"
                    aria-expanded="false"
                    aria-controls={secretId}
                    data-secret-trigger
                  >
                    {secret.trigger}
                  </button>
                  <div id={secretId} class="course-map__secret-panel hidden" data-secret-panel>
                    <p>{secret.title}</p>
                    <span>{secret.message}</span>
                  </div>
                </div>
              )
            }
          </footer>
        </section>
      )
    }

    <slot />

    <h2 class="mt-14 font-display text-3xl font-bold lowercase">units</h2>
    <ol class="mt-6 space-y-3">
      {
        units.map((unit, i) => (
          <li class="flex items-baseline gap-4 border-b-2 border-line pb-3">
            <span class="shrink-0 font-display font-bold text-accent">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <span class="font-semibold">{unit.name}</span>
              {unit.current && (
                <span class="ml-2 rounded-full bg-accent px-2 py-0.5 font-mono text-xs lowercase text-white">
                  current
                </span>
              )}
              <p class="mt-0.5 text-sm text-ink-soft">{unit.blurb}</p>
              {unit.topics && unit.topics.length > 0 && (
                <details class="group mt-1.5">
                  <summary class="cursor-pointer select-none font-mono text-xs lowercase text-accent hover:text-accent-dark">
                    <span class="group-open:hidden">what's inside +</span>
                    <span class="hidden group-open:inline">what's inside −</span>
                  </summary>
                  <ul class="mb-1 mt-2 space-y-1 text-sm text-ink-soft">
                    {unit.topics.map((topic) => (
                      <li class="flex gap-2">
                        <span class="text-accent">·</span>
                        <span>{topic}</span>
                      </li>
                    ))}
                  </ul>
                </details>
              )}
              {unit.materials && unit.materials.length > 0 && (
                <ul class="mt-2 flex flex-wrap gap-x-4 gap-y-1">
                  {unit.materials.map((material) => (
                    <li>
                      <a
                        href={material.href}
                        target="_blank"
                        rel="noopener"
                        class="font-mono text-xs lowercase text-accent underline underline-offset-4 hover:text-accent-dark"
                      >
                        {material.label} ↗
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))
      }
    </ol>

    {
      glossary.length > 0 && (
        <>
          <h2 class="mt-14 font-display text-3xl font-bold lowercase">words worth knowing</h2>
          <p class="mt-2 text-sm text-ink-soft">Click a term. Definitions in plain English, mostly.</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            {glossary.map((entry) => (
              <details class="rounded-md border-2 border-line bg-white px-4 py-3 transition-colors open:border-accent">
                <summary class="cursor-pointer select-none font-semibold lowercase marker:text-accent">{entry.term}</summary>
                <p class="mt-2 text-sm leading-relaxed text-ink-soft">{entry.def}</p>
              </details>
            ))}
          </div>
        </>
      )
    }

    {
      resources.length > 0 && (
        <>
          <h2 class="mt-14 font-display text-3xl font-bold lowercase">resources</h2>
          <ul class="mt-4 space-y-2">
            {resources.map((resource) => (
              <li>
                <a href={resource.href} class="text-accent underline underline-offset-4 hover:text-accent-dark">
                  {resource.label}
                </a>
              </li>
            ))}
          </ul>
        </>
      )
    }
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLElement>('[data-course-secret]').forEach((secret) => {
    const trigger = secret.querySelector<HTMLButtonElement>('[data-secret-trigger]');
    const panel = secret.querySelector<HTMLElement>('[data-secret-panel]');
    if (!trigger || !panel) return;

    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!isOpen));
      panel.classList.toggle('hidden', isOpen);
    });
  });
</script>

<style>
  .course-page--history {
    --color-accent: #a63a2f;
    --color-accent-dark: #72271f;
    --color-accent-soft: #fff0ed;
  }

  .course-page--classified {
    --color-accent: #765200;
    --color-accent-dark: #503800;
    --color-accent-soft: #fff6ce;
  }

  .course-page--scoreboard {
    --color-accent: #08765a;
    --color-accent-dark: #04503d;
    --color-accent-soft: #e4fff5;
  }

  .course-map {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
    border-radius: 1.1rem;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent-soft) 54%, white) 0%, white 42%),
      white;
    box-shadow: 0 24px 55px -44px rgb(23 23 28 / 0.7);
  }

  .course-map::before {
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent) 0 28%, color-mix(in srgb, var(--color-accent) 18%, transparent) 66%, transparent);
    content: '';
  }

  .course-map__header,
  .course-map__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.4rem;
  }

  .course-map__header {
    border-bottom: 1px solid var(--color-line);
  }

  .course-map__status,
  .course-map__count,
  .course-map__eyebrow,
  .course-map__progress-label {
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .course-map__status {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-accent-dark);
    font-size: 0.64rem;
  }

  .course-map__status-dot {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .course-map__count {
    color: var(--color-ink);
    font-size: 0.68rem;
  }

  .course-map__count span {
    color: var(--color-ink-soft);
    font-weight: 500;
  }

  .course-map__layout {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
  }

  .course-map__now,
  .course-map__route {
    padding: 1.65rem 1.4rem 1.75rem;
  }

  .course-map__now {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: 15.5rem;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    border-right: 1px solid var(--color-line);
  }

  .course-map__ghost-number {
    position: absolute;
    z-index: -1;
    right: -0.25rem;
    bottom: -1.55rem;
    color: color-mix(in srgb, var(--color-accent) 7%, transparent);
    font-family: var(--font-display);
    font-size: clamp(8rem, 14vw, 11rem);
    font-weight: 700;
    letter-spacing: -0.1em;
    line-height: 1;
  }

  .course-map__eyebrow {
    color: var(--color-accent-dark);
    font-size: 0.61rem;
  }

  .course-map__title {
    position: relative;
    max-width: 27rem;
    margin-top: 0.55rem;
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 3.2vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.03;
  }

  .course-map__blurb {
    position: relative;
    max-width: 29rem;
    margin-top: 0.8rem;
    color: var(--color-ink-soft);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .course-map__route {
    background: rgb(255 255 255 / 0.72);
  }

  .course-map__units {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.35rem;
    margin-top: 0.8rem;
  }

  .course-map__unit {
    display: grid;
    grid-template-columns: 1.8rem minmax(0, 1fr);
    align-items: center;
    gap: 0.62rem;
    min-height: 2.55rem;
    padding: 0.38rem 0.55rem;
    border: 1px solid transparent;
    border-radius: 0.7rem;
    color: var(--color-ink-soft);
  }

  .course-map__unit-number {
    display: flex;
    width: 1.75rem;
    height: 1.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: white;
    color: var(--color-ink-soft);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
  }

  .course-map__unit-name {
    min-width: 0;
    font-size: 0.73rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .course-map__unit[data-state='current'] {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: white;
    box-shadow: 0 8px 22px -18px var(--color-ink);
  }

  .course-map__unit[data-state='current'] .course-map__unit-number {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: white;
  }

  .course-map__unit[data-state='complete'] {
    background: var(--color-accent-soft);
    color: var(--color-accent-dark);
  }

  .course-map__unit[data-state='complete'] .course-map__unit-number {
    border-color: color-mix(in srgb, var(--color-accent) 28%, transparent);
    color: var(--color-accent-dark);
  }

  .course-map__footer {
    align-items: flex-start;
    border-top: 1px solid var(--color-line);
    background: rgb(250 250 247 / 0.72);
  }

  .course-map__progress {
    width: min(100%, 25rem);
  }

  .course-map__progress-label {
    display: flex;
    justify-content: space-between;
    color: var(--color-ink-soft);
    font-size: 0.55rem;
  }

  .course-map__progress-track {
    height: 0.3rem;
    margin-top: 0.5rem;
    overflow: hidden;
    border-radius: 999px;
    background: var(--color-line);
  }

  .course-map__progress-track span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--color-accent);
  }

  .course-map__secret {
    max-width: 24rem;
    text-align: right;
  }

  .course-map__secret button {
    color: var(--color-ink-soft);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
    text-underline-offset: 0.3rem;
  }

  .course-map__secret button:hover {
    color: var(--color-accent-dark);
  }

  .course-map__secret-panel {
    margin-top: 0.8rem;
    padding: 0.8rem 0.9rem;
    border-left: 3px solid var(--color-accent);
    background: var(--color-accent-soft);
    text-align: left;
  }

  .course-map__secret-panel p {
    color: var(--color-accent-dark);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .course-map__secret-panel span {
    display: block;
    margin-top: 0.35rem;
    color: var(--color-ink-soft);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  @media (max-width: 767px) {
    .course-map__layout {
      grid-template-columns: 1fr;
    }

    .course-map__now {
      min-height: 13.5rem;
      border-right: 0;
      border-bottom: 1px solid var(--color-line);
    }

    .course-map__units {
      grid-template-columns: 1fr;
    }

    .course-map__footer {
      align-items: stretch;
      flex-direction: column;
    }

    .course-map__progress {
      width: 100%;
    }

    .course-map__secret {
      max-width: none;
      text-align: left;
    }
  }
</style>
