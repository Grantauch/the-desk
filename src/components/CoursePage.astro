---
// Shared template for the three active course pages.
import Base from '../layouts/Base.astro';

interface Unit {
  name: string;
  blurb: string;
  current?: boolean;
  topics?: string[];
  materials?: { label: string; href: string }[];
}

interface Resource {
  label: string;
  href: string;
}

interface GlossaryEntry {
  term: string;
  def: string;
}

interface CourseSecret {
  trigger: string;
  title: string;
  message: string;
}

interface Props {
  title: string;
  tagline: string;
  intro: string;
  units: Unit[];
  resources: Resource[];
  glossary?: GlossaryEntry[];
  theme?: 'history' | 'classified' | 'scoreboard';
  identityLabel?: string;
  secret?: CourseSecret;
}

const {
  title,
  tagline,
  intro,
  units,
  resources,
  glossary = [],
  theme = 'history',
  identityLabel,
  secret,
} = Astro.props;
const currentIndex = units.findIndex((unit) => unit.current);
const currentUnit = currentIndex >= 0 ? units[currentIndex] : undefined;
const hasHero = Astro.slots.has('hero');
const hasHook = Astro.slots.has('hook');
const secretId = `course-secret-${theme}`;
---

<Base title={title}>
  <div class:list={['course-page', `course-page--${theme}`]}>
    {identityLabel && <p class="font-mono text-[0.68rem] font-bold uppercase tracking-[0.2em] text-accent">{identityLabel}</p>}
    <h1 class:list={[identityLabel ? 'mt-3' : '', 'font-display text-5xl font-bold lowercase tracking-tight sm:text-6xl']}>
      {title}<span class="text-accent">.</span>
    </h1>
    <p class="mt-3 text-lg lowercase text-ink-soft">{tagline}</p>

    {hasHero && <slot name="hero" />}

    <p class:list={[hasHero ? 'mt-10' : 'mt-6', 'max-w-2xl leading-relaxed']}>{intro}</p>

    {hasHook && <div class="mt-10"><slot name="hook" /></div>}

    {
      currentUnit && (
        <section class="pop-ink mt-10 rounded-md bg-accent p-6 text-white" aria-labelledby="right-now-title">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <p class="font-mono text-xs uppercase tracking-widest text-white/70">right now</p>
            <p class="font-mono text-[0.68rem] font-bold uppercase tracking-[0.15em] text-white/70">
              unit {currentIndex + 1} of {units.length}
            </p>
          </div>
          <h2 id="right-now-title" class="mt-1 font-display text-2xl font-bold">{currentUnit.name}</h2>
          <p class="mt-1 text-white/85">{currentUnit.blurb}</p>

          <div class="mt-5 border-t border-white/20 pt-4">
            <p class="font-mono text-[0.62rem] font-bold uppercase tracking-[0.16em] text-white/65">course trail</p>
            <ol class="mt-3 flex items-center" aria-label={`Course progress: unit ${currentIndex + 1} of ${units.length}`}>
              {
                units.map((unit, i) => (
                  <li
                    class="flex min-w-0 flex-1 items-center last:flex-none"
                    aria-current={i === currentIndex ? 'step' : undefined}
                    title={`Unit ${i + 1}: ${unit.name}`}
                  >
                    <span
                      class:list={[
                        'flex h-5 w-5 shrink-0 items-center justify-center rounded-full border-2 font-mono text-[0.55rem] font-bold sm:h-7 sm:w-7 sm:text-[0.65rem]',
                        i < currentIndex && 'border-white bg-white text-accent',
                        i === currentIndex && 'border-white bg-ink text-white',
                        i > currentIndex && 'border-white/45 text-white/65',
                      ]}
                    >
                      {i + 1}
                      <span class="sr-only">: {unit.name}</span>
                    </span>
                    {i < units.length - 1 && <span class:list={['h-0.5 min-w-0 flex-1', i < currentIndex ? 'bg-white' : 'bg-white/30']} aria-hidden="true"></span>}
                  </li>
                ))
              }
            </ol>
          </div>

          {
            secret && (
              <div class="mt-4 border-t border-white/20 pt-3" data-course-secret>
                <button
                  type="button"
                  class="font-mono text-[0.64rem] font-bold lowercase tracking-[0.12em] text-white/60 underline decoration-white/30 underline-offset-4 transition-colors hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
                  aria-expanded="false"
                  aria-controls={secretId}
                  data-secret-trigger
                >
                  {secret.trigger}
                </button>
                <div id={secretId} class="mt-3 hidden rounded-sm border border-white/25 bg-black/20 p-4" data-secret-panel>
                  <p class="font-mono text-[0.62rem] font-bold uppercase tracking-[0.16em] text-white/60">{secret.title}</p>
                  <p class="mt-2 text-sm leading-relaxed text-white/90">{secret.message}</p>
                </div>
              </div>
            )
          }
        </section>
      )
    }

    <slot />

    <h2 class="mt-14 font-display text-3xl font-bold lowercase">units</h2>
    <ol class="mt-6 space-y-3">
      {
        units.map((unit, i) => (
          <li class="flex items-baseline gap-4 border-b-2 border-line pb-3">
            <span class="shrink-0 font-display font-bold text-accent">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <span class="font-semibold">{unit.name}</span>
              {unit.current && (
                <span class="ml-2 rounded-full bg-accent px-2 py-0.5 font-mono text-xs lowercase text-white">
                  current
                </span>
              )}
              <p class="mt-0.5 text-sm text-ink-soft">{unit.blurb}</p>
              {unit.topics && unit.topics.length > 0 && (
                <details class="group mt-1.5">
                  <summary class="cursor-pointer select-none font-mono text-xs lowercase text-accent hover:text-accent-dark">
                    <span class="group-open:hidden">what's inside +</span>
                    <span class="hidden group-open:inline">what's inside −</span>
                  </summary>
                  <ul class="mb-1 mt-2 space-y-1 text-sm text-ink-soft">
                    {unit.topics.map((topic) => (
                      <li class="flex gap-2">
                        <span class="text-accent">·</span>
                        <span>{topic}</span>
                      </li>
                    ))}
                  </ul>
                </details>
              )}
              {unit.materials && unit.materials.length > 0 && (
                <ul class="mt-2 flex flex-wrap gap-x-4 gap-y-1">
                  {unit.materials.map((material) => (
                    <li>
                      <a
                        href={material.href}
                        target="_blank"
                        rel="noopener"
                        class="font-mono text-xs lowercase text-accent underline underline-offset-4 hover:text-accent-dark"
                      >
                        {material.label} ↗
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))
      }
    </ol>

    {
      glossary.length > 0 && (
        <>
          <h2 class="mt-14 font-display text-3xl font-bold lowercase">words worth knowing</h2>
          <p class="mt-2 text-sm text-ink-soft">Click a term. Definitions in plain English, mostly.</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            {glossary.map((entry) => (
              <details class="rounded-md border-2 border-line bg-white px-4 py-3 transition-colors open:border-accent">
                <summary class="cursor-pointer select-none font-semibold lowercase marker:text-accent">{entry.term}</summary>
                <p class="mt-2 text-sm leading-relaxed text-ink-soft">{entry.def}</p>
              </details>
            ))}
          </div>
        </>
      )
    }

    {
      resources.length > 0 && (
        <>
          <h2 class="mt-14 font-display text-3xl font-bold lowercase">resources</h2>
          <ul class="mt-4 space-y-2">
            {resources.map((resource) => (
              <li>
                <a href={resource.href} class="text-accent underline underline-offset-4 hover:text-accent-dark">
                  {resource.label}
                </a>
              </li>
            ))}
          </ul>
        </>
      )
    }
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLElement>('[data-course-secret]').forEach((secret) => {
    const trigger = secret.querySelector<HTMLButtonElement>('[data-secret-trigger]');
    const panel = secret.querySelector<HTMLElement>('[data-secret-panel]');
    if (!trigger || !panel) return;

    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!isOpen));
      panel.classList.toggle('hidden', isOpen);
    });
  });
</script>

<style>
  .course-page--history {
    --color-accent: #a63a2f;
    --color-accent-dark: #72271f;
    --color-accent-soft: #fff0ed;
  }

  .course-page--classified {
    --color-accent: #765200;
    --color-accent-dark: #503800;
    --color-accent-soft: #fff6ce;
  }

  .course-page--scoreboard {
    --color-accent: #08765a;
    --color-accent-dark: #04503d;
    --color-accent-soft: #e4fff5;
  }
</style>
