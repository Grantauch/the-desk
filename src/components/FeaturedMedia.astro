---
interface Props {
  id?: string;
  eyebrow: string;
  title: string;
  description: string;
  src: string;
  poster?: string;
  duration?: string;
  credit?: string;
  accessibleDescription?: string;
  aspect?: 'portrait' | 'square' | 'landscape';
}

const {
  id,
  eyebrow,
  title,
  description,
  src,
  poster,
  duration,
  credit,
  accessibleDescription = description,
  aspect = 'square',
} = Astro.props;
const mediaId = id ?? `featured-media-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;
const titleId = `${mediaId}-title`;
const descriptionId = `${mediaId}-description`;
---

<section
  id={mediaId}
  class="featured-media mt-8 overflow-hidden rounded-md border-2 border-ink bg-ink text-white shadow-[7px_7px_0_0_#ff5c35]"
  aria-labelledby={titleId}
>
  <div class="grid lg:grid-cols-[minmax(17rem,0.78fr)_minmax(22rem,1.22fr)]">
    <div class="relative flex flex-col justify-between overflow-hidden p-6 sm:p-8">
      <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full border-[24px] border-white/[0.035]" aria-hidden="true"></div>

      <div class="relative">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-white/65">
          <span class="inline-flex items-center gap-2 text-[#ff8a6d]">
            <span class="featured-media__pulse h-2 w-2 rounded-full bg-[#ff5c35]" aria-hidden="true"></span>
            field reel
          </span>
          {duration && <span>{duration}</span>}
        </div>

        <p class="mt-8 font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#ff8a6d]">{eyebrow}</p>
        <h2 id={titleId} class="mt-3 max-w-xl font-display text-4xl font-bold lowercase leading-[0.98] sm:text-5xl">
          {title}<span class="text-[#ff5c35]">.</span>
        </h2>
        <p class="mt-5 max-w-lg leading-relaxed text-white/78">{description}</p>
      </div>

      <div class="relative mt-8 border-t border-white/15 pt-5">
        <p class="font-mono text-xs font-bold lowercase tracking-wide text-white">press play. turn it up.</p>
        {credit && <p class="mt-2 text-xs lowercase text-white/45">credit: {credit}</p>}
      </div>
    </div>

    <div class="relative flex justify-center border-t-2 border-white/10 bg-black lg:border-l-2 lg:border-t-0">
      <div class="pointer-events-none absolute left-3 top-3 z-10 rounded-sm bg-black/65 px-2 py-1 font-mono text-[0.62rem] font-bold uppercase tracking-[0.16em] text-white/70 backdrop-blur-sm">
        normandy // 06.06.44
      </div>
      <video
        class:list={[
          'max-h-[42rem] w-full bg-black object-contain',
          aspect === 'square' && 'aspect-square',
          aspect === 'portrait' && 'aspect-[9/16] max-w-[24rem]',
          aspect === 'landscape' && 'aspect-video',
        ]}
        controls
        playsinline
        preload="metadata"
        poster={poster}
        aria-describedby={descriptionId}
      >
        <source src={src} type="video/mp4" />
        Your browser does not support embedded video.
      </video>
      <p id={descriptionId} class="sr-only">{accessibleDescription}</p>
    </div>
  </div>
</section>

<style>
  @keyframes featured-media-pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.45;
      transform: scale(0.72);
    }
  }

  .featured-media__pulse {
    animation: featured-media-pulse 1.6s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-media__pulse {
      animation: none;
    }
  }
</style>
