---
// Nav.astro — top navigation. To add a page, add one entry to `links`.
const links = [
  { href: '/us-history/', label: 'us history' },
  { href: '/economics/', label: 'economics' },
  { href: '/law/', label: 'law' },
  { href: '/simulations/', label: 'simulations' },
  { href: '/tools/', label: 'tools' },
  { href: '/announcements/', label: 'announcements' },
  { href: '/about/', label: 'about' },
];

const current = Astro.url.pathname;
---

<header class="border-b-2 border-ink bg-paper/90 backdrop-blur sticky top-0 z-10">
  <div class="max-w-4xl mx-auto px-5 py-4 flex flex-wrap items-baseline gap-x-8 gap-y-2">
    <a href="/" class="font-display text-2xl font-bold tracking-tight lowercase text-ink hover:text-accent transition-colors">
      the desk<span class="text-accent">.</span>
    </a>
    <nav class="flex flex-wrap gap-x-5 gap-y-1 text-sm lowercase">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'transition-colors hover:text-accent border-b-2 pb-0.5',
              current.startsWith(link.href)
                ? 'text-ink font-semibold border-accent'
                : 'text-ink-soft border-transparent',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
