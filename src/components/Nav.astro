---
// Nav.astro — compact primary navigation with a secondary explore menu.
const primaryLinks = [
  { href: '/us-history/', label: 'us history' },
  { href: '/hidden-history/', label: 'hidden history' },
  { href: '/beyond-the-scoreboard/', label: 'beyond the scoreboard' },
  { href: '/resources/', label: 'library' },
];

const exploreLinks = [
  { href: '/glossary/', label: 'glossary' },
  { href: '/simulations/', label: 'simulations' },
  { href: '/games/', label: 'games' },
  { href: '/rabbit-holes/', label: 'rabbit holes' },
  { href: '/tools/', label: 'tools' },
  { href: '/calendar/', label: 'calendar' },
  { href: '/announcements/', label: 'announcements' },
  { href: '/about/', label: 'about' },
];

const current = Astro.url.pathname;
const isActive = (href: string) => current === href || current.startsWith(href);
const exploreIsActive = exploreLinks.some((link) => isActive(link.href));
---

<header class="border-b-2 border-ink bg-paper/90 backdrop-blur sticky top-0 z-10">
  <div class="max-w-4xl mx-auto px-5 py-3.5">
    <div class="flex items-center justify-between gap-6">
      <a href="/" class="font-display text-2xl font-bold tracking-tight lowercase text-ink hover:text-accent transition-colors">
        the desk<span class="text-accent">.</span>
      </a>

      <nav class="hidden items-center gap-5 text-sm lowercase md:flex" aria-label="Primary navigation">
        {
          primaryLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'rounded-lg border-b-2 px-2 py-1.5 transition-all hover:bg-accent-soft hover:text-accent',
                isActive(link.href)
                  ? 'border-accent font-semibold text-ink'
                  : 'border-transparent text-ink-soft',
              ]}
            >
              {link.label}
            </a>
          ))
        }

        <details class="group relative">
          <summary
            class:list={[
              'cursor-pointer list-none rounded-lg border-b-2 px-2 py-1.5 text-ink-soft transition-all hover:bg-accent-soft hover:text-accent [&::-webkit-details-marker]:hidden',
              exploreIsActive ? 'border-accent font-semibold text-ink' : 'border-transparent',
            ]}
          >
            explore <span aria-hidden="true" class="inline-block transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="pop absolute right-0 top-[calc(100%+0.75rem)] z-20 w-56 rounded-md bg-white p-2">
            {
              exploreLinks.map((link) => (
                <a
                  href={link.href}
                  class:list={[
                    'block rounded px-3 py-2 transition-colors hover:bg-accent-soft hover:text-accent',
                    isActive(link.href) ? 'bg-accent-soft font-semibold text-accent' : 'text-ink-soft',
                  ]}
                >
                  {link.label}
                </a>
              ))
            }
          </div>
        </details>
      </nav>
    </div>

    <nav class="mt-3 grid grid-cols-4 gap-1 border-t border-line pt-3 text-center font-mono text-[0.68rem] font-semibold lowercase md:hidden" aria-label="Mobile navigation">
      <a href="/#courses" class="rounded px-1 py-1.5 text-ink-soft transition-colors hover:bg-accent-soft hover:text-accent">courses</a>
      <a
        href="/resources/"
        class:list={[
          'rounded px-1 py-1.5 transition-colors hover:bg-accent-soft hover:text-accent',
          isActive('/resources/') ? 'bg-accent-soft text-accent' : 'text-ink-soft',
        ]}
      >
        library
      </a>
      <a href="/#today" class="rounded px-1 py-1.5 text-ink-soft transition-colors hover:bg-accent-soft hover:text-accent">today</a>
      <details class="group relative">
        <summary class="cursor-pointer list-none rounded px-1 py-1.5 text-ink-soft transition-colors hover:bg-accent-soft hover:text-accent [&::-webkit-details-marker]:hidden">
          explore <span aria-hidden="true" class="inline-block transition-transform group-open:rotate-45">+</span>
        </summary>
        <div class="pop absolute right-0 top-[calc(100%+0.5rem)] z-20 w-56 rounded-md bg-white p-2 text-left font-sans text-sm font-normal">
          <p class="px-3 pb-1 pt-2 font-mono text-[0.65rem] font-semibold text-accent">current classes</p>
          {
            primaryLinks.slice(0, 3).map((link) => (
              <a href={link.href} class="block rounded px-3 py-2 text-ink-soft hover:bg-accent-soft hover:text-accent">
                {link.label}
              </a>
            ))
          }
          <div class="my-1 border-t border-line" />
          {
            exploreLinks.map((link) => (
              <a href={link.href} class="block rounded px-3 py-2 text-ink-soft hover:bg-accent-soft hover:text-accent">
                {link.label}
              </a>
            ))
          }
        </div>
      </details>
    </nav>
  </div>
</header>
