---
// Footer.astro — bottom of every page.
const year = new Date().getFullYear();
---

<footer class="mt-20 bg-ink text-paper">
  <div class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-6 px-5 py-8 lowercase">
    <div class="flex items-center gap-4">
      <img
        src="/mr-grant-approved.png"
        alt="Mr. Grant approved"
        width="82"
        height="82"
        class="footer-stamp shrink-0"
      />
      <span class="font-display text-2xl font-bold tracking-tight">
        the desk<span class="text-accent">.</span>
      </span>
    </div>
    <p class="text-sm text-paper/60">© {year} · grant-desk.com</p>
  </div>
</footer>

<style>
  .footer-stamp {
    border: 3px solid white;
    background: white;
    box-shadow: 0 12px 26px -14px rgb(0 0 0 / 0.8);
    transform: rotate(-3deg);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .footer-stamp:hover {
    box-shadow: 0 16px 30px -12px rgb(31 44 230 / 0.75);
    transform: rotate(0deg) scale(1.04);
  }
</style>
