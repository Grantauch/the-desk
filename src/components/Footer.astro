---
// Footer.astro — bottom of every page.
const year = new Date().getFullYear();
---

<footer class="bg-ink text-paper mt-20">
  <div class="max-w-4xl mx-auto px-5 py-10 flex flex-wrap items-baseline justify-between gap-4 lowercase">
    <span class="font-display text-2xl font-bold tracking-tight">
      the desk<span class="text-accent">.</span>
    </span>
    <div class="text-sm text-paper/60 text-right">
      <p>built from scratch, one commit at a time.</p>
      <p class="mt-1">© {year} · live at grant-desk.com</p>
    </div>
  </div>
</footer>
